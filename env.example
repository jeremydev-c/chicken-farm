# =============================================================
# Tabby Premium Eggs - Environment Variables
# Copy this file to `.env.local` and fill in your real values.
#   PowerShell:  Copy-Item env.example .env.local
# Never commit `.env.local` - it is gitignored.
# =============================================================

# --- Paystack (online payments) ---
# Get your keys from: https://dashboard.paystack.com/#/settings/developers
# Use the TEST secret key (sk_test_...) while developing,
# and the LIVE secret key (sk_live_...) in production.
PAYSTACK_SECRET_KEY=

# Currency to charge. Defaults to KES if omitted.
# Your Paystack account must be enabled for this currency.
PAYSTACK_CURRENCY=KES

# Public base URL of the deployed site, used to build the payment
# callback URL when the request origin cannot be auto-detected.
# Example: https://tabbyeggs.co.ke  (leave blank for local dev)
NEXT_PUBLIC_APP_URL=

# --- Admin panel access ---
# The password the owner types at /admin/login.
ADMIN_PASSWORD=change-this-password
# A long random string used as the session token. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_TOKEN=replace-with-a-long-random-string
